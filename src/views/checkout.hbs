<html lang='vi'>
    <head>
        <meta charset='UTF-8' />
        <title>Thanh toán</title>
        <meta name='viewport' content='width=device-width, initial-scale=1.0' />

        <style>
            body {
                margin: 0;
                font-family: Arial, sans-serif;
                background: #f5f5f5;
            }

            .container {
                max-width: 600px;
                margin: 50px auto;
                background: white;
                padding: 30px;
                border-radius: 10px;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            }

            h1 {
                text-align: center;
                margin-bottom: 30px;
            }

            .payment-method {
                border: 2px solid #eee;
                padding: 15px;
                border-radius: 8px;
                cursor: pointer;
                margin-bottom: 15px;
                transition: 0.3s;
            }

            .payment-method.active {
                border-color: #d82d8b;
                background: #fff0f7;
            }

            .payment-method input {
                margin-right: 10px;
            }

            .qr-section {
                text-align: center;
                margin-top: 30px;
                display: none;
            }

            .qr-section img {
                width: 250px;
                height: 250px;
            }

            .note {
                margin-top: 15px;
                color: #555;
                font-size: 14px;
            }

            .back-btn {
                display: block;
                margin-top: 30px;
                text-align: center;
                text-decoration: none;
                padding: 10px;
                background: black;
                color: white;
                border-radius: 6px;
            }
        </style>
    </head>
    <body>

        <div class='container'>
            <h1>Chọn phương thức thanh toán</h1>

            <div class='payment-method active' onclick="selectMethod('momo')">
                <label>
                    <input type='radio' name='payment' checked />
                    Thanh toán qua MoMo
                </label>
            </div>

            <div class='qr-section' id='momoQR'>
                <!-- DÁN QR MOMO CỦA BẠN VÀO ĐÂY -->
                <img src='/images/momo-qr.png' alt='QR MoMo' />

                <div class='note'>
                    Quét mã QR bằng ứng dụng MoMo để thanh toán.<br />
                    Sau khi chuyển khoản xong vui lòng liên hệ xác nhận.
                </div>
            </div>

            <a href='/' class='back-btn'>Quay về trang chủ</a>
        </div>

        <script>
            function selectMethod(method) {
            document.querySelectorAll('.payment-method').forEach(el => {
            el.classList.remove('active'); });
            event.currentTarget.classList.add('active'); if (method === 'momo')
            { document.getElementById('momoQR').style.display = 'block'; } } //
            Tự động hiện QR khi load window.onload = function() {
            document.getElementById('momoQR').style.display = 'block'; }
        </script>

    </body>
</html>