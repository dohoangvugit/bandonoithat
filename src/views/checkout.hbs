<div class='container py-5'>
    <h1 class='display-5 fw-light mb-4'>Thanh toán đơn hàng</h1>

    {{#if items.length}}
        <div class='row'>
            <div class='col-lg-8'>
                <h5 class='mb-3'>Danh sách sản phẩm</h5>
                <table class='table align-middle'>
                    <thead>
                        <tr>
                            <th>Ảnh</th>
                            <th>Sản phẩm</th>
                            <th>Giá</th>
                            <th>Số lượng</th>
                            <th>Tổng</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each items}}
                            <tr>
                                <td>
                                    <img src='{{this.products.image}}' width='60' />
                                </td>
                                <td>
                                    <b>{{this.products.name}}</b>
                                </td>
                                <td>
                                    {{this.products.price}} VNĐ
                                </td>
                                <td>
                                    {{this.quantity}}
                                </td>
                                <td>
                                    <b>{{multiply this.products.price this.quantity}} VNĐ</b>
                                </td>
                            </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>

            <div class='col-lg-4'>
                <div id='paymentForm' class='card'>
                    <div class='card-body'>
                        <h5 class='card-title'>Tóm tắt đơn hàng</h5>
                        <hr/>
                        <div class='d-flex justify-content-between mb-3'>
                            <span>Tổng tiền:</span>
                            <strong class='text-danger fs-5'>{{formatPrice total}} VNĐ</strong>
                        </div>

                        <button class='btn btn-danger w-100 mb-2' onclick='showMomoQR()'>
                            Thanh toán bằng MoMo
                        </button>

                        <a href='/cart' class='btn btn-secondary w-100'>Quay lại giỏ hàng</a>
                    </div>
                </div>
            </div>
        </div>

        <div id='momoSection' style='display: none; margin-top: 30px;'>
            <div class='row justify-content-center'>
                <div class='col-lg-6'>
                    <div class='card text-center'>
                        <div class='card-body'>
                            <h5 class='card-title mb-4'>Quét mã QR MoMo để thanh toán</h5>
                            <img src='/img/momo.jpg' alt='QR MoMo' class='img-fluid' style='max-width: 350px;' />
                            <p class='text-muted mt-4'>
                                Quét mã QR bằng ứng dụng MoMo để thanh toán.<br/>
                                Số tiền: <strong>{{formatPrice total}} VNĐ</strong>
                            </p>
                            <button class='btn btn-secondary mt-3' onclick='hideMomoQR()'>Hủy</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {{else}}
        <div class='alert alert-info'>
            Giỏ hàng của bạn đang trống. <a href='/'>Quay lại mua sắm</a>
        </div>
    {{/if}}
</div>

<script>
    function showMomoQR() {
        document.getElementById('paymentForm').style.display = 'none';
        document.getElementById('momoSection').style.display = 'block';
    }

    function hideMomoQR() {
        document.getElementById('paymentForm').style.display = 'block';
        document.getElementById('momoSection').style.display = 'none';
    }
</script>